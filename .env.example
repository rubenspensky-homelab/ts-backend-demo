# Core
PORT=3000
SERVICE_NAME=ts-backend-demo
SERVICE_DESCRIPTION=TypeScript backend demo service.
SERVICE_VERSION=1.0.0
NODE_ENV=development
PUBLIC_BASE_URLS=http://localhost:3000|Local

# Observability
METRICS_ENABLED=true
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# OIDC / Authentik
AUTH_PROVIDER=oidc
AUTH_ISSUER=http://auth.home.lab/application/o/frontend-test/
AUTH_JWKS_URL=http://auth.home.lab/application/o/frontend-test/jwks/
AUTH_AUDIENCE=L9JCsgnMIb4CgTE3G4eSe8J5aWDTphvbpX9NM7ui

# Scalar API docs OAuth testing
DOCS_OAUTH_CLIENT_ID=L9JCsgnMIb4CgTE3G4eSe8J5aWDTphvbpX9NM7ui
DOCS_OAUTH_AUTHORIZATION_URL=http://localhost:3000/docs/oauth/authorize
DOCS_OAUTH_UPSTREAM_AUTHORIZATION_URL=http://auth.home.lab/application/o/authorize/
DOCS_OAUTH_TOKEN_URL=http://auth.home.lab/application/o/token/
DOCS_OAUTH_REDIRECT_URI=http://localhost:3000/docs

# Mock auth for local development
# AUTH_PROVIDER=mock
MOCK_USER_ID=dev-user-1
MOCK_USER_EMAIL=dev@example.com
MOCK_USER_NAME=Dev User
MOCK_USER_GROUPS=admins,developers
